# =============================================================================
# Az-Dev-Cleanup .gitignore
# =============================================================================
# Generated report outputs are recreated by running discovery/cleanup scripts.
# Only scripts, queries, policies, and documentation are tracked.

# Discovery report outputs (generated by Invoke-TenantDiscovery.ps1)
reports/
discovery/reports/
discovery/metric-staleness.csv

# Excel workbooks (generated by Export-DiscoveryReport.ps1)
*.xlsx

# Cleanup execution logs (generated by cleanup scripts)
cleanup-dryrun-*/
cleanup-execution-*/
cleanup-log-*.csv
orphaned-resources.csv

# Baseline snapshots (generated by Save-TenantBaseline.ps1)
baseline-*.json

# IDE and tooling
.claude/
.vscode/
*.code-workspace

# OS artifacts
Thumbs.db
Desktop.ini
.DS_Store
